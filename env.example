# /etc/relay-control/env
# ┌─────────────────────────────────────────────────────────┐
# │  Sensitive configuration — readable by root only        │
# │  chmod 640 /etc/relay-control/env                       │
# │  chown root:pi /etc/relay-control/env                   │
# └─────────────────────────────────────────────────────────┘

# API basic-auth credentials — CHANGE THESE BEFORE DEPLOYING
API_USERNAME=admin
API_PASSWORD=changeme

# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-real-secret-key

# GPIO pin (BCM numbering)
RELAY_PIN=17

# Pulse duration in seconds
DEACTIVATE_SECS=10
